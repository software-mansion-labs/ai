---
import MobileTableOfContents from "@astrojs/starlight/components/MobileTableOfContents.astro";
import TableOfContents from "@astrojs/starlight/components/TableOfContents.astro";
import { Icon } from "@astrojs/starlight/components";
import { feedbackUrl } from "../lib/siteLinks";
---

{
  Astro.locals.starlightRoute.toc && (
    <>
      <div class="lg:sl-hidden">
        <MobileTableOfContents />
      </div>
      <div class="right-sidebar-panel sl-hidden lg:sl-block">
        <div class="sl-container">
          <TableOfContents />
        </div>
        <div class="sl-container">
          <a
            class="feedback"
            href={feedbackUrl}
            rel="noopener noreferrer"
            target="_blank"
          >
            <div class="icon" aria-hidden="true">
              <Icon name="comment" size="1.25rem" />
            </div>
            <p class="title">Enjoyed this guide?</p>
            <p class="sub">Let us know what you think</p>
            <span class="cta">Share feedback</span>
          </a>
        </div>
      </div>
    </>
  )
}

<style>
  @layer starlight.core {
    .right-sidebar-panel {
      padding: 1rem var(--sl-sidebar-pad-x);
    }

    .sl-container {
      width: calc(var(--sl-sidebar-width) - 2 * var(--sl-sidebar-pad-x));
    }

    .right-sidebar-panel :global(h2) {
      color: var(--sl-color-white);
      font-size: var(--sl-text-h5);
      font-weight: 600;
      line-height: var(--sl-line-height-headings);
      margin-bottom: 0.5rem;
    }

    .right-sidebar-panel :global(:where(a)) {
      display: block;
      font-size: var(--sl-text-xs);
      text-decoration: none;
      color: var(--sl-color-gray-3);
      overflow-wrap: anywhere;
    }

    .right-sidebar-panel :global(:where(a):hover) {
      color: var(--sl-color-white);
    }

    @media (min-width: 72rem) {
      .sl-container {
        max-width: calc(
          (
            (
              100vw - var(--sl-sidebar-width) - 2 * var(--sl-content-pad-x) -
                2 * var(--sl-sidebar-pad-x)
            )
          )
        );
      }
    }

    .feedback {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin-top: 1.5rem;
      padding: 1rem;
      border: 1px solid var(--sl-color-hairline);
      border-radius: 0.625rem;
      text-decoration: none;
      color: var(--sl-color-white);
    }

    .feedback:focus-visible {
      outline: 2px solid var(--sl-color-text-accent);
      outline-offset: 3px;
    }

    .icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.25rem;
      height: 2.25rem;
      border-radius: 0.5rem;
      background-color: var(--sl-color-accent-low);
      color: var(--sl-color-text-accent);
      flex-shrink: 0;
      margin-bottom: 0.25rem;
    }

    .title {
      margin: 0;
      font-size: var(--sl-text-sm);
      font-weight: 600;
      color: var(--sl-color-white);
      line-height: 1.3;
    }

    .sub {
      margin: 0;
      font-size: var(--sl-text-xs);
      color: var(--sl-color-gray-3);
      line-height: 1.4;
    }

    .cta {
      display: block;
      margin-top: 0.375rem;
      padding: 0.4rem 0.75rem;
      background-color: var(--sl-color-accent);
      color: var(--sl-color-white);
      font-size: var(--sl-text-xs);
      font-weight: 600;
      text-align: center;
      border-radius: 0.375rem;
      transition: opacity 0.15s ease;
    }

    .feedback:hover .cta {
      opacity: 0.82;
    }

    @media (prefers-reduced-motion: reduce) {
      .cta {
        transition: none;
      }
    }
  }
</style>
